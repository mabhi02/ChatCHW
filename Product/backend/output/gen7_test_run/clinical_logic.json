      "source_section_id": "5_2_fever_less_than_7_days_in_a_malaria_area"
    },
    {
      "id": "m_dx_fever_no_malaria",
      "category": "diagnosis",
      "text": "Classification: FEVER, NO MALARIA. RDT negative.",
      "module_context": "mod_fever",
      "source_quote": "RDT negative: FEVER, NO MALARIA",
      "source_section_id": "5_2_fever_less_than_7_days_in_a_malaria_area"
    },
    {
      "id": "m_rx_al",
      "category": "treatment",
      "text": "Give AL (Artemether-Lumefantrine) twice daily for 3 days.",
      "module_context": "mod_fever",
      "source_quote": "Give antimalarial AL",
      "source_section_id": "antimalarial_al_artemether_lumefantrine_dosage"
    },
    {
      "id": "m_refer_fever_prolonged",
      "category": "referral",
      "text": "Fever for 7 days or more. Refer to hospital.",
      "module_context": "mod_fever",
      "source_quote": "If fever for 7 days or more, refer",
      "source_section_id": "fever"
    },
    {
      "id": "m_dx_diarrhoea",
      "category": "diagnosis",
      "text": "Classification: DIARRHOEA. Give ORS and zinc.",
      "module_context": "mod_diarrhoea",
      "source_quote": "If diarrhoea: give ORS and zinc",
      "source_section_id": "diarrhoea"
    },
    {
      "id": "m_dx_dysentery",
      "category": "diagnosis",
      "text": "Classification: DYSENTERY. Blood in stool. Refer.",
