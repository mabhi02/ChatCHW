      "source_section_id": "cough"
    },
    {
      "id": "m_fu_cough_3_days",
      "category": "followup",
      "text": "Follow up in 3 days. If still fast breathing, refer to hospital.",
      "module_context": "mod_cough",
      "source_quote": "Follow up in 3 days for cough with fast breathing",
      "source_section_id": "7_3_follow_up_for_cough_with_fast_breathing"
    },
    {
      "id": "m_dx_malaria",
      "category": "diagnosis",
      "text": "Classification: MALARIA. RDT positive.",
      "module_context": "mod_fever",
