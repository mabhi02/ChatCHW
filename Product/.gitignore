# debugging, exceeds GitHub 100MB push limit.
backend/output/**/rlm_*.jsonl

# Extraction run outputs — generated artifacts per run. Keep locally for
# research reference but don't commit (50-800KB each, accumulates fast).
# Force-add individual files with `git add -f path/to/file` if you want a
# specific run's artifacts in the repo (e.g. the reference WHO run).
backend/output/run_*/
backend/output/arena-*/

