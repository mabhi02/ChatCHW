      <output id="output_mod_check_vaccines_4" label="adv_refer_for_vaccines" name="adv_refer_for_vaccines" typeRef="string"/>
      <output id="output_mod_check_vaccines_5" label="fu_vaccine_referral_advised" name="fu_vaccine_referral_advised" typeRef="string"/>
      <output id="output_mod_check_vaccines_6" label="mod_check_vaccines_done" name="mod_check_vaccines_done" typeRef="string"/>
      <rule id="rule_vcx_no_card">
        <description>No vaccine card present; advise caregiver to bring card to health facility to verify vaccination status and catch up on any missed vaccines.</description>
        <inputEntry id="ie_mod_check_vaccines_0_0">
          <text>hx_vaccine_card_present == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_birth_due">
        <description>Child is under 6 weeks and is missing one or more birth-dose vaccines (BCG, HepB birth, OPV0); refer to health facility for vaccination.</description>
        <inputEntry id="ie_mod_check_vaccines_1_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_weeks &gt;= 0 AND demo_age_in_weeks &lt; 6 AND (hx_bcg_given == false OR hx_hepb_birth_given == false OR hx_opv0_given == false)</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_birth_uptodate_under6wk">
        <description>Child is under 6 weeks and has received all birth-dose vaccines (BCG, HepB birth, OPV0); vaccines are up to date for age. Advise caregiver to return at 6 weeks for next scheduled vaccines.</description>
        <inputEntry id="ie_mod_check_vaccines_2_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_weeks &gt;= 0 AND demo_age_in_weeks &lt; 6 AND hx_bcg_given == true AND hx_hepb_birth_given == true AND hx_opv0_given == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_6wk_due">
        <description>Child is 6 to 9 weeks and is missing one or more 6-week vaccines (DTP-Hib1, HepB1, OPV1, RTV1, PCV1); refer to health facility for vaccination.</description>
        <inputEntry id="ie_mod_check_vaccines_3_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_weeks &gt;= 6 AND demo_age_in_weeks &lt; 10 AND (hx_dtp_hib1_given == false OR hx_hepb1_given == false OR hx_opv1_given == false OR hx_rtv1_given == false OR hx_pcv1_given == false)</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_6wk_uptodate">
        <description>Child is 6 to 9 weeks and has received all vaccines due at 6 weeks; vaccines are up to date for age. Advise caregiver to return at 10 weeks for next scheduled vaccines.</description>
        <inputEntry id="ie_mod_check_vaccines_4_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_weeks &gt;= 6 AND demo_age_in_weeks &lt; 10 AND hx_dtp_hib1_given == true AND hx_hepb1_given == true AND hx_opv1_given == true AND hx_rtv1_given == true AND hx_pcv1_given == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_10wk_due">
        <description>Child is 10 to 13 weeks and is missing one or more 10-week vaccines (DTP-Hib2, HepB2, OPV2, RTV2, PCV2); refer to health facility for vaccination.</description>
        <inputEntry id="ie_mod_check_vaccines_5_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_weeks &gt;= 10 AND demo_age_in_weeks &lt; 14 AND (hx_dtp_hib2_given == false OR hx_hepb2_given == false OR hx_opv2_given == false OR hx_rtv2_given == false OR hx_pcv2_given == false)</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_10wk_uptodate">
        <description>Child is 10 to 13 weeks and has received all vaccines due at 10 weeks; vaccines are up to date for age. Advise caregiver to return at 14 weeks for next scheduled vaccines.</description>
        <inputEntry id="ie_mod_check_vaccines_6_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_weeks &gt;= 10 AND demo_age_in_weeks &lt; 14 AND hx_dtp_hib2_given == true AND hx_hepb2_given == true AND hx_opv2_given == true AND hx_rtv2_given == true AND hx_pcv2_given == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_14wk_due">
        <description>Child is 14 weeks to under 9 months and is missing one or more 14-week vaccines (DTP-Hib3, HepB3, OPV3, RTV3, PCV3); refer to health facility for vaccination.</description>
        <inputEntry id="ie_mod_check_vaccines_7_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_weeks &gt;= 14 AND demo_age_in_months &lt; 9 AND (hx_dtp_hib3_given == false OR hx_hepb3_given == false OR hx_opv3_given == false OR hx_rtv3_given == false OR hx_pcv3_given == false)</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_14wk_uptodate">
        <description>Child is 14 weeks to under 9 months and has received all vaccines due at 14 weeks; vaccines are up to date for age. Advise caregiver to return at 9 months for MCV1.</description>
        <inputEntry id="ie_mod_check_vaccines_8_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_weeks &gt;= 14 AND demo_age_in_months &lt; 9 AND hx_dtp_hib3_given == true AND hx_hepb3_given == true AND hx_opv3_given == true AND hx_rtv3_given == true AND hx_pcv3_given == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_9mo_due">
        <description>Child is 9 to 17 months and has not received MCV1; refer to health facility for vaccination.</description>
        <inputEntry id="ie_mod_check_vaccines_9_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_months &gt;= 9 AND demo_age_in_months &lt; 18 AND hx_mcv1_given == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_9mo_uptodate">
        <description>Child is 9 to 17 months and has received MCV1; vaccines are up to date for age. Advise caregiver to return at 18 months for DTP booster and MCV2.</description>
        <inputEntry id="ie_mod_check_vaccines_10_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_months &gt;= 9 AND demo_age_in_months &lt; 18 AND hx_mcv1_given == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_18mo_due">
        <description>Child is 18 months to under 5 years and is missing one or more 18-month vaccines (DTP booster, MCV2); refer to health facility for vaccination.</description>
        <inputEntry id="ie_mod_check_vaccines_11_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_months &gt;= 18 AND demo_age_in_months &lt; 60 AND (hx_dtp_booster_given == false OR hx_mcv2_given == false)</text>
        </inputEntry>
      </rule>
      <rule id="rule_vcx_18mo_uptodate">
        <description>Child is 18 months to under 5 years and has received all vaccines in the schedule including DTP booster and MCV2; vaccines are fully up to date. Praise caregiver and confirm no further scheduled vaccines in this programme.</description>
        <inputEntry id="ie_mod_check_vaccines_12_0">
          <text>hx_vaccine_card_present == true AND demo_age_in_months &gt;= 18 AND demo_age_in_months &lt; 60 AND hx_dtp_booster_given == true AND hx_mcv2_given == true</text>
        </inputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_mod_danger_sign_check" name="Danger Sign Check and Referral Decision">
    <variable id="var_decision_mod_danger_sign_check" name="mod_danger_sign_check_output" typeRef="string"/>
    <informationRequirement id="ir_mod_danger_sign_check_demo_age_months">
      <requiredInput href="#demo_age_months"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_q_cough_days">
      <requiredInput href="#q_cough_days"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_q_diarrhoea_days">
      <requiredInput href="#q_diarrhoea_days"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_q_blood_in_stool">
      <requiredInput href="#q_blood_in_stool"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_q_fever_days">
