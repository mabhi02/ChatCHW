        </inputExpression>
      </input>
      <input id="input_mod_assess_50" label="p_vaccine_due">
        <inputExpression id="ie_mod_assess_50" typeRef="boolean">
          <text>p_vaccine_due</text>
        </inputExpression>
      </input>
      <output id="output_mod_assess_0" label="mod_assess_done" name="mod_assess_done" typeRef="string"/>
      <output id="output_mod_assess_1" label="p_danger_sign_present" name="p_danger_sign_present" typeRef="string"/>
      <output id="output_mod_assess_2" label="p_fast_breathing" name="p_fast_breathing" typeRef="string"/>
      <output id="output_mod_assess_3" label="p_severe_malnutrition" name="p_severe_malnutrition" typeRef="string"/>
      <output id="output_mod_assess_4" label="p_moderate_malnutrition" name="p_moderate_malnutrition" typeRef="string"/>
      <output id="output_mod_assess_5" label="p_diarrhoea_uncomplicated" name="p_diarrhoea_uncomplicated" typeRef="string"/>
      <output id="output_mod_assess_6" label="p_fever_uncomplicated" name="p_fever_uncomplicated" typeRef="string"/>
      <output id="output_mod_assess_7" label="p_pneumonia" name="p_pneumonia" typeRef="string"/>
      <output id="output_mod_assess_8" label="p_vaccine_due" name="p_vaccine_due" typeRef="string"/>
      <output id="output_mod_assess_9" label="p_refer_urgently" name="p_refer_urgently" typeRef="string"/>
      <output id="output_mod_assess_10" label="p_pre_referral_ors" name="p_pre_referral_ors" typeRef="string"/>
      <output id="output_mod_assess_11" label="p_pre_referral_rectal_artesunate" name="p_pre_referral_rectal_artesunate" typeRef="string"/>
      <output id="output_mod_assess_12" label="p_pre_referral_first_dose_al" name="p_pre_referral_first_dose_al" typeRef="string"/>
      <output id="output_mod_assess_13" label="p_pre_referral_first_dose_amoxicillin" name="p_pre_referral_first_dose_amoxicillin" typeRef="string"/>
      <output id="output_mod_assess_14" label="ref_destination" name="ref_destination" typeRef="string"/>
      <output id="output_mod_assess_15" label="ref_urgency" name="ref_urgency" typeRef="string"/>
      <output id="output_mod_assess_16" label="ref_reason" name="ref_reason" typeRef="string"/>
      <output id="output_mod_assess_17" label="is_priority_exit" name="is_priority_exit" typeRef="string"/>
      <output id="output_mod_assess_18" label="priority_exit_destination" name="priority_exit_destination" typeRef="string"/>
      <output id="output_mod_assess_19" label="flag_mod_treat_diarrhoea" name="flag_mod_treat_diarrhoea" typeRef="string"/>
      <output id="output_mod_assess_20" label="flag_mod_treat_fever" name="flag_mod_treat_fever" typeRef="string"/>
      <output id="output_mod_assess_21" label="flag_mod_treat_pneumonia" name="flag_mod_treat_pneumonia" typeRef="string"/>
      <output id="output_mod_assess_22" label="flag_mod_treat_malnutrition" name="flag_mod_treat_malnutrition" typeRef="string"/>
      <output id="output_mod_assess_23" label="flag_mod_treat_severe_malnutrition" name="flag_mod_treat_severe_malnutrition" typeRef="string"/>
      <output id="output_mod_assess_24" label="flag_mod_counsel_feeding" name="flag_mod_counsel_feeding" typeRef="string"/>
      <output id="output_mod_assess_25" label="flag_mod_vaccines" name="flag_mod_vaccines" typeRef="string"/>
      <output id="output_mod_assess_26" label="flag_mod_home_care" name="flag_mod_home_care" typeRef="string"/>
      <output id="output_mod_assess_27" label="flag_mod_pre_referral" name="flag_mod_pre_referral" typeRef="string"/>
      <rule id="rule_1">
        <description>ANY danger sign present (cough &gt;=14 days, diarrhoea &gt;=14 days, blood in stool, fever &gt;=7 days, convulsions, unable to drink/feed, vomits everything, chest indrawing, unusually sleepy/unconscious, red MUAC &lt;115mm, bilateral foot oedema): refer urgently to hospital. Set pre-referral treatment flags based on specific combination of danger signs.</description>
        <inputEntry id="ie_mod_assess_0_0">
          <text>(q_cough_present == true &amp;&amp; q_cough_duration_days &gt;= 14) || (q_diarrhoea_present == true &amp;&amp; q_diarrhoea_duration_days &gt;= 14) || (q_blood_in_stool == true) || (q_fever_present == true &amp;&amp; q_fever_duration_days &gt;= 7) || (q_convulsions_present == true) || (q_able_to_drink_feed == false) || (q_vomits_everything == true) || (ex_chest_indrawing == true) || (ex_unusually_sleepy_unconscious == true) || (v_muac_mm &lt; 115) || (ex_bilateral_foot_oedema == true)</text>
        </inputEntry>
      </rule>
      <rule id="rule_2">
        <description>No danger signs. Cough present (&lt;14 days), no chest indrawing, fast breathing present (&gt;=50 bpm for 2-12 months OR &gt;=40 bpm for 12-60 months): classify as pneumonia. Also assess and flag co-existing uncomplicated diarrhoea and uncomplicated fever for treatment modules. Flag home care and vaccine check.</description>
        <inputEntry id="ie_mod_assess_1_0">
          <text>p_danger_sign_present == false &amp;&amp; q_cough_present == true &amp;&amp; q_cough_duration_days &lt; 14 &amp;&amp; ex_chest_indrawing == false &amp;&amp; ((demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 12 &amp;&amp; ex_respiratory_rate_bpm &gt;= 50) || (demo_age_months &gt;= 12 &amp;&amp; demo_age_months &lt; 60 &amp;&amp; ex_respiratory_rate_bpm &gt;= 40))</text>
        </inputEntry>
      </rule>
      <rule id="rule_3">
        <description>No danger signs. Cough present (&lt;14 days), no chest indrawing, no fast breathing. Uncomplicated diarrhoea present (&lt;14 days, no blood). Also check for co-existing uncomplicated fever. Flag diarrhoea treatment module, conditionally fever module, home care, and vaccine check.</description>
        <inputEntry id="ie_mod_assess_2_0">
          <text>p_danger_sign_present == false &amp;&amp; q_cough_present == true &amp;&amp; q_cough_duration_days &lt; 14 &amp;&amp; ex_chest_indrawing == false &amp;&amp; !((demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 12 &amp;&amp; ex_respiratory_rate_bpm &gt;= 50) || (demo_age_months &gt;= 12 &amp;&amp; demo_age_months &lt; 60 &amp;&amp; ex_respiratory_rate_bpm &gt;= 40)) &amp;&amp; (q_diarrhoea_present == true &amp;&amp; q_diarrhoea_duration_days &lt; 14 &amp;&amp; q_blood_in_stool == false)</text>
        </inputEntry>
      </rule>
      <rule id="rule_4">
        <description>No danger signs. Cough present (&lt;14 days), no chest indrawing, no fast breathing, no uncomplicated diarrhoea. Uncomplicated fever present (&lt;7 days) in malaria endemic area. Flag fever treatment (RDT) module, home care, and vaccine check.</description>
        <inputEntry id="ie_mod_assess_3_0">
          <text>p_danger_sign_present == false &amp;&amp; q_cough_present == true &amp;&amp; q_cough_duration_days &lt; 14 &amp;&amp; ex_chest_indrawing == false &amp;&amp; !((demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 12 &amp;&amp; ex_respiratory_rate_bpm &gt;= 50) || (demo_age_months &gt;= 12 &amp;&amp; demo_age_months &lt; 60 &amp;&amp; ex_respiratory_rate_bpm &gt;= 40)) &amp;&amp; (q_diarrhoea_present == false || (q_diarrhoea_present == true &amp;&amp; q_diarrhoea_duration_days &lt; 14 &amp;&amp; q_blood_in_stool == false) == false) &amp;&amp; (q_fever_present == true &amp;&amp; q_fever_duration_days &lt; 7 &amp;&amp; p_malaria_endemic_area == true)</text>
        </inputEntry>
      </rule>
      <rule id="rule_5">
        <description>No danger signs. No pneumonia. Uncomplicated diarrhoea (&lt;14 days, no blood). Optionally co-existing uncomplicated fever in malaria area. Flag diarrhoea and conditionally fever treatment modules, home care, and vaccine check.</description>
        <inputEntry id="ie_mod_assess_4_0">
          <text>p_danger_sign_present == false &amp;&amp; (q_cough_present == false || (q_cough_present == true &amp;&amp; q_cough_duration_days &lt; 14 &amp;&amp; ex_chest_indrawing == false &amp;&amp; !((demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 12 &amp;&amp; ex_respiratory_rate_bpm &gt;= 50) || (demo_age_months &gt;= 12 &amp;&amp; demo_age_months &lt; 60 &amp;&amp; ex_respiratory_rate_bpm &gt;= 40)))) &amp;&amp; (q_diarrhoea_present == true &amp;&amp; q_diarrhoea_duration_days &lt; 14 &amp;&amp; q_blood_in_stool == false) &amp;&amp; (q_fever_present == false || (q_fever_present == true &amp;&amp; q_fever_duration_days &lt; 7 &amp;&amp; p_malaria_endemic_area == true))</text>
        </inputEntry>
      </rule>
      <rule id="rule_6">
        <description>No danger signs. No cough or cough without fast breathing or chest indrawing. No diarrhoea. Uncomplicated fever (&lt;7 days) in malaria endemic area. Flag fever treatment (RDT) module, home care, and vaccine check.</description>
        <inputEntry id="ie_mod_assess_5_0">
          <text>p_danger_sign_present == false &amp;&amp; (q_cough_present == false || (q_cough_present == true &amp;&amp; q_cough_duration_days &lt; 14 &amp;&amp; ex_chest_indrawing == false &amp;&amp; !((demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 12 &amp;&amp; ex_respiratory_rate_bpm &gt;= 50) || (demo_age_months &gt;= 12 &amp;&amp; demo_age_months &lt; 60 &amp;&amp; ex_respiratory_rate_bpm &gt;= 40)))) &amp;&amp; (q_diarrhoea_present == false) &amp;&amp; (q_fever_present == true &amp;&amp; q_fever_duration_days &lt; 7 &amp;&amp; p_malaria_endemic_area == true)</text>
        </inputEntry>
      </rule>
      <rule id="rule_7">
        <description>No danger signs from main list, but MUAC red (&lt;115mm) or bilateral foot oedema without any other treatable condition: severe acute malnutrition. Refer urgently to health facility. Note: v_muac_mm &lt; 115 and bilateral foot oedema are also independently listed as danger signs in rule_1; this rule covers isolated SAM presentation.</description>
        <inputEntry id="ie_mod_assess_6_0">
          <text>p_danger_sign_present == false &amp;&amp; (q_cough_present == false || (q_cough_present == true &amp;&amp; q_cough_duration_days &lt; 14 &amp;&amp; ex_chest_indrawing == false &amp;&amp; !((demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 12 &amp;&amp; ex_respiratory_rate_bpm &gt;= 50) || (demo_age_months &gt;= 12 &amp;&amp; demo_age_months &lt; 60 &amp;&amp; ex_respiratory_rate_bpm &gt;= 40)))) &amp;&amp; q_diarrhoea_present == false &amp;&amp; (q_fever_present == false || (q_fever_present == true &amp;&amp; (q_fever_duration_days &gt;= 7 || p_malaria_endemic_area == false))) &amp;&amp; (v_muac_mm &lt; 115 || ex_bilateral_foot_oedema == true)</text>
        </inputEntry>
      </rule>
      <rule id="rule_8">
        <description>No danger signs, no acute illness requiring treatment. MUAC yellow (115-124mm), no oedema: moderate malnutrition. Counsel on feeding. Flag vaccine check and home care advice.</description>
        <inputEntry id="ie_mod_assess_7_0">
          <text>p_danger_sign_present == false &amp;&amp; (q_cough_present == false || (q_cough_present == true &amp;&amp; q_cough_duration_days &lt; 14 &amp;&amp; ex_chest_indrawing == false &amp;&amp; !((demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 12 &amp;&amp; ex_respiratory_rate_bpm &gt;= 50) || (demo_age_months &gt;= 12 &amp;&amp; demo_age_months &lt; 60 &amp;&amp; ex_respiratory_rate_bpm &gt;= 40)))) &amp;&amp; q_diarrhoea_present == false &amp;&amp; (q_fever_present == false || (q_fever_present == true &amp;&amp; (q_fever_duration_days &gt;= 7 || p_malaria_endemic_area == false))) &amp;&amp; v_muac_mm &gt;= 115 &amp;&amp; v_muac_mm &lt; 125 &amp;&amp; ex_bilateral_foot_oedema == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_9">
        <description>No danger signs, no acute illness, MUAC green (&gt;=125mm), no oedema: well child. Check vaccination status and provide general home care/prevention advice.</description>
        <inputEntry id="ie_mod_assess_8_0">
          <text>p_danger_sign_present == false &amp;&amp; (q_cough_present == false || (q_cough_present == true &amp;&amp; q_cough_duration_days &lt; 14 &amp;&amp; ex_chest_indrawing == false &amp;&amp; !((demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 12 &amp;&amp; ex_respiratory_rate_bpm &gt;= 50) || (demo_age_months &gt;= 12 &amp;&amp; demo_age_months &lt; 60 &amp;&amp; ex_respiratory_rate_bpm &gt;= 40)))) &amp;&amp; q_diarrhoea_present == false &amp;&amp; (q_fever_present == false || (q_fever_present == true &amp;&amp; (q_fever_duration_days &gt;= 7 || p_malaria_endemic_area == false))) &amp;&amp; v_muac_mm &gt;= 125 &amp;&amp; ex_bilateral_foot_oedema == false</text>
        </inputEntry>
      </rule>
    </decisionTable>
  </decision>
