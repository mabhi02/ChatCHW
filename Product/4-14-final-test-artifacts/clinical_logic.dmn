      <input id="input_mod_home_care_advice_29" label="ref_health_facility">
        <inputExpression id="ie_mod_home_care_advice_29" typeRef="boolean">
          <text>ref_health_facility</text>
        </inputExpression>
      </input>
      <input id="input_mod_home_care_advice_30" label="adv_fluids_given">
        <inputExpression id="ie_mod_home_care_advice_30" typeRef="boolean">
          <text>adv_fluids_given</text>
        </inputExpression>
      </input>
      <input id="input_mod_home_care_advice_31" label="adv_feeding_given">
        <inputExpression id="ie_mod_home_care_advice_31" typeRef="boolean">
          <text>adv_feeding_given</text>
        </inputExpression>
      </input>
      <input id="input_mod_home_care_advice_32" label="adv_when_to_return_given">
        <inputExpression id="ie_mod_home_care_advice_32" typeRef="boolean">
          <text>adv_when_to_return_given</text>
        </inputExpression>
      </input>
      <input id="input_mod_home_care_advice_33" label="adv_bednet_given">
        <inputExpression id="ie_mod_home_care_advice_33" typeRef="boolean">
          <text>adv_bednet_given</text>
        </inputExpression>
      </input>
      <input id="input_mod_home_care_advice_34" label="fu_3day_scheduled">
        <inputExpression id="ie_mod_home_care_advice_34" typeRef="boolean">
          <text>fu_3day_scheduled</text>
        </inputExpression>
      </input>
      <input id="input_mod_home_care_advice_35" label="p_vaccine_check_needed">
        <inputExpression id="ie_mod_home_care_advice_35" typeRef="boolean">
          <text>p_vaccine_check_needed</text>
        </inputExpression>
      </input>
      <output id="output_mod_home_care_advice_0" label="adv_fluids_given" name="adv_fluids_given" typeRef="string"/>
      <output id="output_mod_home_care_advice_1" label="adv_feeding_given" name="adv_feeding_given" typeRef="string"/>
      <output id="output_mod_home_care_advice_2" label="adv_when_to_return_signs" name="adv_when_to_return_signs" typeRef="string"/>
      <output id="output_mod_home_care_advice_3" label="adv_when_to_return_given" name="adv_when_to_return_given" typeRef="string"/>
      <output id="output_mod_home_care_advice_4" label="adv_bednet_given" name="adv_bednet_given" typeRef="string"/>
      <output id="output_mod_home_care_advice_5" label="adv_counsel_feeding_muac_yellow" name="adv_counsel_feeding_muac_yellow" typeRef="string"/>
      <output id="output_mod_home_care_advice_6" label="fu_3day_scheduled" name="fu_3day_scheduled" typeRef="string"/>
      <output id="output_mod_home_care_advice_7" label="fu_reason" name="fu_reason" typeRef="string"/>
      <output id="output_mod_home_care_advice_8" label="adv_return_immediately_signs" name="adv_return_immediately_signs" typeRef="string"/>
      <output id="output_mod_home_care_advice_9" label="adv_home_care_summary" name="adv_home_care_summary" typeRef="string"/>
      <output id="output_mod_home_care_advice_10" label="mod_home_care_advice_done" name="mod_home_care_advice_done" typeRef="string"/>
      <rule id="rule_1">
        <description>Child has danger sign(s) and urgent referral is indicated with pre-referral treatment already given. Skip home care advice; focus on immediate transfer to hospital.</description>
        <inputEntry id="ie_mod_home_care_advice_0_0">
          <text>p_refer_urgently == true AND p_pre_referral_given == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_2">
        <description>Child has danger sign(s) and urgent referral is indicated but pre-referral treatment not yet recorded as given. Flag for pre-referral treatment and immediate hospital transfer.</description>
        <inputEntry id="ie_mod_home_care_advice_1_0">
          <text>p_refer_urgently == true AND p_pre_referral_given == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_3">
        <description>Child has severe acute malnutrition (MUAC red or bilateral oedema) without other urgent danger signs already triggering referral. Refer to health facility; home care advice is not appropriate primary action.</description>
        <inputEntry id="ie_mod_home_care_advice_2_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_4">
        <description>Child treated for diarrhoea only (ORS + zinc). Provide home care advice on fluids, feeding, when to return, bednet use. Schedule 3-day follow-up.</description>
        <inputEntry id="ie_mod_home_care_advice_3_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_diarrhoea_treated == true AND p_fever_treated == false AND p_fast_breathing_treated == false AND p_malnutrition_moderate == false AND p_rdt_negative == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_5">
        <description>Child treated for fever with confirmed malaria (RDT positive, AL prescribed). Provide home care advice on fluids, feeding, completing AL course, when to return, bednet. Schedule 3-day follow-up.</description>
        <inputEntry id="ie_mod_home_care_advice_4_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_fever_treated == true AND lab_rdt_result == 'positive' AND p_diarrhoea_treated == false AND p_fast_breathing_treated == false AND p_malnutrition_moderate == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_6">
        <description>Child has fever but RDT negative. No antimalarial given. Provide home care advice and mandatory 3-day follow-up to reassess fever cause.</description>
        <inputEntry id="ie_mod_home_care_advice_5_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_fever_treated == true AND lab_rdt_result == 'negative' AND p_diarrhoea_treated == false AND p_fast_breathing_treated == false AND p_malnutrition_moderate == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_7">
        <description>Child treated for fast breathing (non-severe pneumonia) with amoxicillin. Provide home care advice on fluids, feeding, completing antibiotic course, when to return, bednet. Schedule 3-day follow-up.</description>
        <inputEntry id="ie_mod_home_care_advice_6_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_fast_breathing_treated == true AND p_diarrhoea_treated == false AND p_fever_treated == false AND p_malnutrition_moderate == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_8">
        <description>Child treated for both diarrhoea and confirmed malaria fever. Provide combined home care advice covering ORS, zinc completion, AL completion, when to return, bednet. Schedule 3-day follow-up.</description>
        <inputEntry id="ie_mod_home_care_advice_7_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_diarrhoea_treated == true AND p_fever_treated == true AND lab_rdt_result == 'positive' AND p_fast_breathing_treated == false AND p_malnutrition_moderate == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_9">
        <description>Child treated for both diarrhoea and fast breathing. Provide combined home care advice. Schedule 3-day follow-up.</description>
        <inputEntry id="ie_mod_home_care_advice_8_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_diarrhoea_treated == true AND p_fast_breathing_treated == true AND p_fever_treated == false AND p_malnutrition_moderate == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_10">
        <description>Child treated for both fast breathing and confirmed malaria. Provide combined home care advice. Schedule 3-day follow-up.</description>
        <inputEntry id="ie_mod_home_care_advice_9_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_fast_breathing_treated == true AND p_fever_treated == true AND lab_rdt_result == 'positive' AND p_diarrhoea_treated == false AND p_malnutrition_moderate == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_11">
        <description>Child treated for diarrhoea, fast breathing, and confirmed malaria. Provide comprehensive home care advice. Schedule 3-day follow-up.</description>
        <inputEntry id="ie_mod_home_care_advice_10_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_diarrhoea_treated == true AND p_fast_breathing_treated == true AND p_fever_treated == true AND lab_rdt_result == 'positive' AND p_malnutrition_moderate == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_12">
        <description>Child has yellow MUAC (moderate malnutrition) without acute treatable illness. Provide feeding counselling, fluid advice, when to return, bednet advice. Schedule 3-day follow-up for nutrition reassessment.</description>
        <inputEntry id="ie_mod_home_care_advice_11_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_malnutrition_moderate == true AND p_any_illness_treated == false AND p_diarrhoea_treated == false AND p_fever_treated == false AND p_fast_breathing_treated == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_13">
        <description>Child treated for acute illness and also has yellow MUAC. Provide home care advice including illness-specific guidance plus feeding counselling. Schedule 3-day follow-up.</description>
        <inputEntry id="ie_mod_home_care_advice_12_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_malnutrition_moderate == true AND p_any_illness_treated == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_14">
        <description>Child has no acute illness but has missing vaccinations identified. Provide general home care advice and refer for vaccination. No 3-day follow-up required for illness but vaccination referral made.</description>
        <inputEntry id="ie_mod_home_care_advice_13_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_malnutrition_moderate == false AND p_any_illness_treated == false AND p_diarrhoea_treated == false AND p_fever_treated == false AND p_fast_breathing_treated == false AND p_vaccine_check_needed == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_15">
        <description>Child assessed with no illness, no malnutrition, vaccinations current. Provide general preventive home care advice. No follow-up scheduled.</description>
        <inputEntry id="ie_mod_home_care_advice_14_0">
          <text>p_refer_urgently == false AND p_malnutrition_severe == false AND p_malnutrition_moderate == false AND p_any_illness_treated == false AND p_diarrhoea_treated == false AND p_fever_treated == false AND p_fast_breathing_treated == false AND p_vaccine_check_needed == false</text>
        </inputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_mod_malnutrition_screening" name="Malnutrition Screening - MUAC and Oedema">
    <variable id="var_decision_mod_malnutrition_screening" name="mod_malnutrition_screening_output" typeRef="string"/>
    <informationRequirement id="ir_mod_malnutrition_screening_demo_age_months">
      <requiredInput href="#demo_age_months"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_malnutrition_screening_v_muac_colour">
      <requiredInput href="#v_muac_colour"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_malnutrition_screening_ex_bilateral_foot_oedema">
      <requiredInput href="#ex_bilateral_foot_oedema"/>
    </informationRequirement>
    <decisionTable id="dt_mod_malnutrition_screening" hitPolicy="UNIQUE">
      <input id="input_mod_malnutrition_screening_0" label="demo_age_months">
        <inputExpression id="ie_mod_malnutrition_screening_0" typeRef="boolean">
          <text>demo_age_months</text>
        </inputExpression>
      </input>
      <input id="input_mod_malnutrition_screening_1" label="v_muac_colour">
        <inputExpression id="ie_mod_malnutrition_screening_1" typeRef="boolean">
          <text>v_muac_colour</text>
        </inputExpression>
      </input>
      <input id="input_mod_malnutrition_screening_2" label="ex_bilateral_foot_oedema">
        <inputExpression id="ie_mod_malnutrition_screening_2" typeRef="boolean">
          <text>ex_bilateral_foot_oedema</text>
        </inputExpression>
      </input>
      <output id="output_mod_malnutrition_screening_0" label="p_severe_acute_malnutrition" name="p_severe_acute_malnutrition" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_1" label="p_moderate_acute_malnutrition" name="p_moderate_acute_malnutrition" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_2" label="p_malnutrition_normal" name="p_malnutrition_normal" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_3" label="p_malnutrition_not_assessed" name="p_malnutrition_not_assessed" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_4" label="ref_urgent_referral_hospital" name="ref_urgent_referral_hospital" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_5" label="ref_reason_severe_malnutrition" name="ref_reason_severe_malnutrition" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_6" label="ref_reason_bilateral_oedema" name="ref_reason_bilateral_oedema" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_7" label="adv_counsel_feeding" name="adv_counsel_feeding" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_8" label="adv_muac_yellow_followup" name="adv_muac_yellow_followup" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_9" label="is_priority_exit" name="is_priority_exit" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_10" label="priority_exit_destination" name="priority_exit_destination" typeRef="string"/>
      <output id="output_mod_malnutrition_screening_11" label="mod_malnutrition_screening_done" name="mod_malnutrition_screening_done" typeRef="string"/>
      <rule id="rule_1">
        <description>Child 6mo-5yr with red MUAC (&lt;115mm) and no bilateral foot oedema: severe acute malnutrition. Refer urgently to hospital.</description>
        <inputEntry id="ie_mod_malnutrition_screening_0_0">
          <text>demo_age_months &gt;= 6 AND demo_age_months &lt; 60 AND v_muac_colour == 'red' AND ex_bilateral_foot_oedema == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_2">
        <description>Child 6mo-5yr with red MUAC (&lt;115mm) AND bilateral foot oedema: severe acute malnutrition with oedema. Refer urgently to hospital.</description>
        <inputEntry id="ie_mod_malnutrition_screening_1_0">
          <text>demo_age_months &gt;= 6 AND demo_age_months &lt; 60 AND v_muac_colour == 'red' AND ex_bilateral_foot_oedema == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_3">
        <description>Child 6mo-5yr with bilateral foot oedema (regardless of MUAC colour): severe malnutrition due to oedema. Refer urgently to hospital.</description>
        <inputEntry id="ie_mod_malnutrition_screening_2_0">
          <text>demo_age_months &gt;= 6 AND demo_age_months &lt; 60 AND v_muac_colour != 'red' AND ex_bilateral_foot_oedema == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_4">
        <description>Child 6mo-5yr with yellow MUAC (115-124mm) and no bilateral foot oedema: moderate acute malnutrition. Counsel on feeding and schedule follow-up.</description>
        <inputEntry id="ie_mod_malnutrition_screening_3_0">
          <text>demo_age_months &gt;= 6 AND demo_age_months &lt; 60 AND v_muac_colour == 'yellow' AND ex_bilateral_foot_oedema == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_5">
        <description>Child 6mo-5yr with green MUAC (&gt;=125mm) and no bilateral foot oedema: no acute malnutrition detected. No additional malnutrition action required.</description>
        <inputEntry id="ie_mod_malnutrition_screening_4_0">
          <text>demo_age_months &gt;= 6 AND demo_age_months &lt; 60 AND v_muac_colour == 'green' AND ex_bilateral_foot_oedema == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_6">
        <description>Child is outside the 6mo-5yr age range for MUAC-based malnutrition screening. Module marked done without malnutrition classification.</description>
        <inputEntry id="ie_mod_malnutrition_screening_5_0">
          <text>demo_age_months &lt; 6 OR demo_age_months &gt;= 60</text>
        </inputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_router" name="Router">
    <decisionTable id="dt_router" hitPolicy="PRIORITY">
      <input id="input_router_condition" label="condition">
        <inputExpression typeRef="string">
          <text>condition</text>
        </inputExpression>
      </input>
      <output id="output_router_module" label="output_module" typeRef="string"/>
      <rule id="rule_router_0">
        <inputEntry id="ie_router_0_0">
          <text>is_priority_exit == true</text>
        </inputEntry>
        <outputEntry id="oe_router_0">
          <text>&quot;PRIORITY_EXIT&quot;</text>
        </outputEntry>
        <description>Short-circuit: if any module has flagged priority exit (danger sign found), go to urgent referral pathway</description>
      </rule>
      <rule id="rule_router_1">
        <inputEntry id="ie_router_1_0">
          <text>mod_assess_done == false</text>
        </inputEntry>
        <outputEntry id="oe_router_1">
          <text>&quot;mod_assess&quot;</text>
        </outputEntry>
        <description>Startup: run Identify Problems - ASK and LOOK first</description>
      </rule>
      <rule id="rule_router_2">
        <inputEntry id="ie_router_2_0">
          <text>mod_assess_done == true AND mod_danger_sign_check_done == false</text>
        </inputEntry>
        <outputEntry id="oe_router_2">
          <text>&quot;mod_danger_sign_check&quot;</text>
        </outputEntry>
        <description>Danger sign module: Danger Sign Check and Referral Decision</description>
      </rule>
      <rule id="rule_router_3">
        <inputEntry id="ie_router_3_0">
          <text>mod_assess_done == true AND mod_check_vaccines_done == false</text>
        </inputEntry>
        <outputEntry id="oe_router_3">
          <text>&quot;mod_check_vaccines&quot;</text>
        </outputEntry>
        <description>Clinical module: Check Vaccines Received</description>
      </rule>
      <rule id="rule_router_4">
        <inputEntry id="ie_router_4_0">
          <text>q_has_diarrhoea == true AND mod_diarrhoea_treatment_done == false</text>
        </inputEntry>
        <outputEntry id="oe_router_4">
          <text>&quot;mod_diarrhoea_treatment&quot;</text>
        </outputEntry>
        <description>Clinical module: Diarrhoea Treatment - ORS and Zinc</description>
      </rule>
      <rule id="rule_router_5">
        <inputEntry id="ie_router_5_0">
          <text>p_fast_breathing == true AND mod_fast_breathing_treatment_done == false</text>
        </inputEntry>
        <outputEntry id="oe_router_5">
          <text>&quot;mod_fast_breathing_treatment&quot;</text>
        </outputEntry>
        <description>Clinical module: Fast Breathing Treatment - Amoxicillin</description>
      </rule>
      <rule id="rule_router_6">
        <inputEntry id="ie_router_6_0">
          <text>q_has_fever == true AND mod_fever_malaria_treatment_done == false</text>
        </inputEntry>
        <outputEntry id="oe_router_6">
          <text>&quot;mod_fever_malaria_treatment&quot;</text>
        </outputEntry>
        <description>Clinical module: Fever/Malaria Treatment - RDT and AL</description>
      </rule>
      <rule id="rule_router_7">
        <inputEntry id="ie_router_7_0">
          <text>mod_assess_done == true AND mod_malnutrition_screening_done == false</text>
        </inputEntry>
        <outputEntry id="oe_router_7">
          <text>&quot;mod_malnutrition_screening&quot;</text>
        </outputEntry>
        <description>Clinical module: Malnutrition Screening - MUAC and Oedema</description>
      </rule>
      <rule id="rule_router_8">
        <inputEntry id="ie_router_8_0">
          <text>true</text>
        </inputEntry>
        <outputEntry id="oe_router_8">
          <text>&quot;mod_home_care_advice&quot;</text>
        </outputEntry>
        <description>Closing: Home Care Advice and Follow-Up Scheduling</description>
      </rule>
    </decisionTable>
  </decision>
</definitions>
