          <text>ex_bilateral_foot_oedema</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_10" label="q_fever_duration_days">
        <inputExpression id="ie_mod_fast_breathing_treatment_10" typeRef="boolean">
          <text>q_fever_duration_days</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_11" label="q_diarrhoea_duration_days">
        <inputExpression id="ie_mod_fast_breathing_treatment_11" typeRef="boolean">
