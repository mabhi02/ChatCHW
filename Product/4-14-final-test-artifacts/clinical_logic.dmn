      <input id="input_mod_fever_malaria_treatment_10" label="lab_rdt_result">
        <inputExpression id="ie_mod_fever_malaria_treatment_10" typeRef="boolean">
          <text>lab_rdt_result</text>
        </inputExpression>
      </input>
      <input id="input_mod_fever_malaria_treatment_11" label="demo_age_months">
        <inputExpression id="ie_mod_fever_malaria_treatment_11" typeRef="boolean">
          <text>demo_age_months</text>
        </inputExpression>
      </input>
      <input id="input_mod_fever_malaria_treatment_12" label="p_malaria_area">
        <inputExpression id="ie_mod_fever_malaria_treatment_12" typeRef="boolean">
          <text>p_malaria_area</text>
        </inputExpression>
      </input>
      <output id="output_mod_fever_malaria_treatment_0" label="lab_rdt_performed" name="lab_rdt_performed" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_1" label="rx_al_tabs_per_dose" name="rx_al_tabs_per_dose" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_2" label="rx_al_doses_per_day" name="rx_al_doses_per_day" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_3" label="rx_al_duration_days" name="rx_al_duration_days" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_4" label="rx_al_total_tabs" name="rx_al_total_tabs" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_5" label="rx_al_indication" name="rx_al_indication" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_6" label="rx_rectal_artesunate_suppositories" name="rx_rectal_artesunate_suppositories" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_7" label="rx_first_dose_al_prereferral" name="rx_first_dose_al_prereferral" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_8" label="ref_urgently" name="ref_urgently" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_9" label="ref_destination" name="ref_destination" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_10" label="ref_reason" name="ref_reason" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_11" label="adv_home_care" name="adv_home_care" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_12" label="adv_bednet" name="adv_bednet" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_13" label="adv_when_to_return" name="adv_when_to_return" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_14" label="fu_days" name="fu_days" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_15" label="is_priority_exit" name="is_priority_exit" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_16" label="priority_exit_destination" name="priority_exit_destination" typeRef="string"/>
      <output id="output_mod_fever_malaria_treatment_17" label="mod_fever_malaria_treatment_done" name="mod_fever_malaria_treatment_done" typeRef="string"/>
      <rule id="rule_1">
        <description>Fever lasting 7 or more days is a danger sign requiring urgent referral to health facility regardless of other findings.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_0_0">
          <text>q_has_fever == true AND q_fever_days &gt;= 7</text>
        </inputEntry>
      </rule>
      <rule id="rule_2">
        <description>Fever &lt;7 days with convulsions or unconsciousness in child 2-35 months in malaria area: give 1 rectal artesunate suppository as pre-referral treatment and refer urgently.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_1_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND (q_convulsions == true OR ex_unconscious == true) AND demo_age_months &gt;= 2 AND demo_age_months &lt; 36</text>
        </inputEntry>
      </rule>
      <rule id="rule_3">
        <description>Fever &lt;7 days with convulsions or unconsciousness in child 36-59 months in malaria area: give 2 rectal artesunate suppositories as pre-referral treatment and refer urgently.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_2_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND (q_convulsions == true OR ex_unconscious == true) AND demo_age_months &gt;= 36 AND demo_age_months &lt; 60</text>
        </inputEntry>
      </rule>
      <rule id="rule_4">
        <description>Fever &lt;7 days with unusually sleepy, vomits everything, or unable to drink (cannot take oral treatment) in child 2-35 months in malaria area: give 1 rectal artesunate suppository as pre-referral treatment and refer urgently.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_3_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND q_convulsions == false AND ex_unconscious == false AND (ex_unusually_sleepy == true OR q_vomits_everything == true OR q_able_to_drink == false) AND demo_age_months &gt;= 2 AND demo_age_months &lt; 36</text>
        </inputEntry>
      </rule>
      <rule id="rule_5">
        <description>Fever &lt;7 days with unusually sleepy, vomits everything, or unable to drink (cannot take oral treatment) in child 36-59 months in malaria area: give 2 rectal artesunate suppositories as pre-referral treatment and refer urgently.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_4_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND q_convulsions == false AND ex_unconscious == false AND (ex_unusually_sleepy == true OR q_vomits_everything == true OR q_able_to_drink == false) AND demo_age_months &gt;= 36 AND demo_age_months &lt; 60</text>
        </inputEntry>
      </rule>
      <rule id="rule_6">
        <description>Fever &lt;7 days, RDT positive, child can drink but has another danger sign (chest indrawing, bilateral foot oedema, or red MUAC) in 2-35 months: give first dose AL (1 tab) as pre-referral and refer urgently to health facility.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_5_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND q_convulsions == false AND ex_unconscious == false AND ex_unusually_sleepy == false AND q_vomits_everything == false AND q_able_to_drink == true AND (ex_chest_indrawing == true OR ex_bilateral_foot_oedema == true OR v_muac_category == 'red') AND lab_rdt_result == 'positive' AND demo_age_months &gt;= 2 AND demo_age_months &lt; 36</text>
        </inputEntry>
      </rule>
      <rule id="rule_7">
        <description>Fever &lt;7 days, RDT positive, child can drink but has another danger sign (chest indrawing, bilateral foot oedema, or red MUAC) in 36-59 months: give first dose AL (2 tabs) as pre-referral and refer urgently to health facility.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_6_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND q_convulsions == false AND ex_unconscious == false AND ex_unusually_sleepy == false AND q_vomits_everything == false AND q_able_to_drink == true AND (ex_chest_indrawing == true OR ex_bilateral_foot_oedema == true OR v_muac_category == 'red') AND lab_rdt_result == 'positive' AND demo_age_months &gt;= 36 AND demo_age_months &lt; 60</text>
        </inputEntry>
      </rule>
      <rule id="rule_8">
        <description>Fever &lt;7 days, RDT negative, child can drink but has another danger sign (chest indrawing, bilateral foot oedema, or red MUAC): refer urgently to health facility without AL.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_7_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND q_convulsions == false AND ex_unconscious == false AND ex_unusually_sleepy == false AND q_vomits_everything == false AND q_able_to_drink == true AND (ex_chest_indrawing == true OR ex_bilateral_foot_oedema == true OR v_muac_category == 'red') AND lab_rdt_result == 'negative' AND demo_age_months &gt;= 2 AND demo_age_months &lt; 60</text>
        </inputEntry>
      </rule>
      <rule id="rule_9">
        <description>Fever &lt;7 days, RDT positive, no danger signs, no other referral criteria, child 2-35 months: treat with AL 1 tab twice daily for 3 days (6 tabs total), give home care advice, and follow up in 3 days.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_8_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND q_convulsions == false AND ex_unconscious == false AND ex_unusually_sleepy == false AND q_vomits_everything == false AND q_able_to_drink == true AND ex_chest_indrawing == false AND ex_bilateral_foot_oedema == false AND v_muac_category != 'red' AND lab_rdt_result == 'positive' AND demo_age_months &gt;= 2 AND demo_age_months &lt; 36</text>
        </inputEntry>
      </rule>
      <rule id="rule_10">
        <description>Fever &lt;7 days, RDT positive, no danger signs, no other referral criteria, child 36-59 months: treat with AL 2 tabs twice daily for 3 days (12 tabs total), give home care advice, and follow up in 3 days.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_9_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND q_convulsions == false AND ex_unconscious == false AND ex_unusually_sleepy == false AND q_vomits_everything == false AND q_able_to_drink == true AND ex_chest_indrawing == false AND ex_bilateral_foot_oedema == false AND v_muac_category != 'red' AND lab_rdt_result == 'positive' AND demo_age_months &gt;= 36 AND demo_age_months &lt; 60</text>
        </inputEntry>
      </rule>
      <rule id="rule_11">
        <description>Fever &lt;7 days, RDT negative, no danger signs, no other referral criteria: malaria not confirmed, do not give AL, give home care advice, and follow up in 3 days to reassess cause of fever.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_10_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == true AND q_convulsions == false AND ex_unconscious == false AND ex_unusually_sleepy == false AND q_vomits_everything == false AND q_able_to_drink == true AND ex_chest_indrawing == false AND ex_bilateral_foot_oedema == false AND v_muac_category != 'red' AND lab_rdt_result == 'negative' AND demo_age_months &gt;= 2 AND demo_age_months &lt; 60</text>
        </inputEntry>
      </rule>
      <rule id="rule_12">
        <description>Fever &lt;7 days but child is NOT in a malaria area: RDT and AL are not indicated. Provide home care advice and follow up in 3 days. Other modules will assess other causes of fever.</description>
        <inputEntry id="ie_mod_fever_malaria_treatment_11_0">
          <text>q_has_fever == true AND q_fever_days &lt; 7 AND p_malaria_area == false AND demo_age_months &gt;= 2 AND demo_age_months &lt; 60</text>
        </inputEntry>
      </rule>
    </decisionTable>
  </decision>
