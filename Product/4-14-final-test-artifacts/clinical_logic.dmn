      <output id="output_mod_fast_breathing_treatment_2" label="rx_amoxicillin_dose_description" name="rx_amoxicillin_dose_description" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_3" label="rx_amoxicillin_pre_referral_dose" name="rx_amoxicillin_pre_referral_dose" typeRef="string"/>
