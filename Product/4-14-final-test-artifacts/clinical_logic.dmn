      <output id="output_mod_fast_breathing_treatment_9" label="adv_continue_feeding" name="adv_continue_feeding" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_10" label="adv_when_to_return" name="adv_when_to_return" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_11" label="adv_bednet" name="adv_bednet" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_12" label="fu_follow_up_days" name="fu_follow_up_days" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_13" label="is_priority_exit" name="is_priority_exit" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_14" label="priority_exit_destination" name="priority_exit_destination" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_15" label="p_refer_urgently" name="p_refer_urgently" typeRef="string"/>
      <rule id="rule_1">
        <description>Fast breathing WITH chest indrawing AND a danger sign meaning child cannot drink/feed or vomits everything or has convulsions or is unusually sleepy/unconscious: give pre-referral first dose amoxicillin and refer urgently to hospital</description>
        <inputEntry id="ie_mod_fast_breathing_treatment_0_0">
          <text>p_fast_breathing == true AND ex_chest_indrawing == true AND (ex_unable_to_drink_or_feed == true OR ex_vomits_everything == true OR ex_convulsions == true OR ex_unusually_sleepy_or_unconscious == true)</text>
        </inputEntry>
      </rule>
      <rule id="rule_2">
        <description>Fast breathing WITH chest indrawing but NO critical danger signs and child can drink: give pre-referral first dose amoxicillin and refer urgently to health facility</description>
        <inputEntry id="ie_mod_fast_breathing_treatment_1_0">
          <text>p_fast_breathing == true AND ex_chest_indrawing == true AND ex_unable_to_drink_or_feed == false AND ex_vomits_everything == false AND ex_convulsions == false AND ex_unusually_sleepy_or_unconscious == false</text>
        </inputEntry>
      </rule>
      <rule id="rule_3">
        <description>Fast breathing WITHOUT chest indrawing BUT with a general danger sign (unable to drink/feed, vomits everything, convulsions, unusually sleepy/unconscious) OR cough &gt;=14 days OR red MUAC OR bilateral foot oedema: refer urgently to hospital without amoxicillin treatment (danger sign takes priority)</description>
        <inputEntry id="ie_mod_fast_breathing_treatment_2_0">
          <text>p_fast_breathing == true AND ex_chest_indrawing == false AND (ex_unable_to_drink_or_feed == true OR ex_vomits_everything == true OR ex_convulsions == true OR ex_unusually_sleepy_or_unconscious == true OR v_muac_color == 'red' OR ex_bilateral_foot_oedema == true OR q_cough_duration_days &gt;= 14)</text>
        </inputEntry>
      </rule>
      <rule id="rule_4">
        <description>Fast breathing, no chest indrawing, no danger signs, age 2-12 months: treat at home with amoxicillin 250mg 1 tablet twice daily x5 days (10 tablets total), home care advice, follow up in 3 days</description>
        <inputEntry id="ie_mod_fast_breathing_treatment_3_0">
          <text>p_fast_breathing == true AND ex_chest_indrawing == false AND ex_unable_to_drink_or_feed == false AND ex_vomits_everything == false AND ex_convulsions == false AND ex_unusually_sleepy_or_unconscious == false AND v_muac_color != 'red' AND ex_bilateral_foot_oedema == false AND q_cough_duration_days &lt; 14 AND demo_age_in_months &gt;= 2 AND demo_age_in_months &lt; 12</text>
        </inputEntry>
      </rule>
      <rule id="rule_5">
        <description>Fast breathing, no chest indrawing, no danger signs, age 12 months to 5 years: treat at home with amoxicillin 250mg 2 tablets twice daily x5 days (20 tablets total), home care advice, follow up in 3 days</description>
        <inputEntry id="ie_mod_fast_breathing_treatment_4_0">
          <text>p_fast_breathing == true AND ex_chest_indrawing == false AND ex_unable_to_drink_or_feed == false AND ex_vomits_everything == false AND ex_convulsions == false AND ex_unusually_sleepy_or_unconscious == false AND v_muac_color != 'red' AND ex_bilateral_foot_oedema == false AND q_cough_duration_days &lt; 14 AND demo_age_in_months &gt;= 12 AND demo_age_in_months &lt; 60</text>
        </inputEntry>
      </rule>
    </decisionTable>
  </decision>
