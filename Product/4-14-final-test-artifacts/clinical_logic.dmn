    </informationRequirement>
    <informationRequirement id="ir_mod_fast_breathing_treatment_q_diarrhoea_duration_days">
      <requiredInput href="#q_diarrhoea_duration_days"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_fast_breathing_treatment_q_blood_in_stool">
      <requiredInput href="#q_blood_in_stool"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_fast_breathing_treatment_v_respiratory_rate_bpm">
      <requiredInput href="#v_respiratory_rate_bpm"/>
    </informationRequirement>
    <decisionTable id="dt_mod_fast_breathing_treatment" hitPolicy="UNIQUE">
      <input id="input_mod_fast_breathing_treatment_0" label="p_fast_breathing">
        <inputExpression id="ie_mod_fast_breathing_treatment_0" typeRef="boolean">
          <text>p_fast_breathing</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_1" label="ex_chest_indrawing">
        <inputExpression id="ie_mod_fast_breathing_treatment_1" typeRef="boolean">
          <text>ex_chest_indrawing</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_2" label="demo_age_in_months">
        <inputExpression id="ie_mod_fast_breathing_treatment_2" typeRef="boolean">
          <text>demo_age_in_months</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_3" label="q_cough_duration_days">
        <inputExpression id="ie_mod_fast_breathing_treatment_3" typeRef="boolean">
          <text>q_cough_duration_days</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_4" label="ex_unable_to_drink_or_feed">
        <inputExpression id="ie_mod_fast_breathing_treatment_4" typeRef="boolean">
          <text>ex_unable_to_drink_or_feed</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_5" label="ex_vomits_everything">
        <inputExpression id="ie_mod_fast_breathing_treatment_5" typeRef="boolean">
          <text>ex_vomits_everything</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_6" label="ex_convulsions">
