    <informationRequirement id="ir_mod_danger_sign_check_ex_not_able_to_drink_or_feed">
      <requiredInput href="#ex_not_able_to_drink_or_feed"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_ex_vomits_everything">
      <requiredInput href="#ex_vomits_everything"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_ex_chest_indrawing">
      <requiredInput href="#ex_chest_indrawing"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_ex_unusually_sleepy_or_unconscious">
      <requiredInput href="#ex_unusually_sleepy_or_unconscious"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_v_muac_category">
      <requiredInput href="#v_muac_category"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_ex_swelling_both_feet">
      <requiredInput href="#ex_swelling_both_feet"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_ex_fast_breathing">
      <requiredInput href="#ex_fast_breathing"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_lab_rdt_result">
      <requiredInput href="#lab_rdt_result"/>
    </informationRequirement>
    <informationRequirement id="ir_mod_danger_sign_check_p_malaria_area">
      <requiredInput href="#p_malaria_area"/>
    </informationRequirement>
    <decisionTable id="dt_mod_danger_sign_check" hitPolicy="UNIQUE">
      <input id="input_mod_danger_sign_check_0" label="demo_age_months">
        <inputExpression id="ie_mod_danger_sign_check_0" typeRef="boolean">
          <text>demo_age_months</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_1" label="q_cough_days">
        <inputExpression id="ie_mod_danger_sign_check_1" typeRef="boolean">
          <text>q_cough_days</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_2" label="q_diarrhoea_days">
        <inputExpression id="ie_mod_danger_sign_check_2" typeRef="boolean">
          <text>q_diarrhoea_days</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_3" label="q_blood_in_stool">
        <inputExpression id="ie_mod_danger_sign_check_3" typeRef="boolean">
          <text>q_blood_in_stool</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_4" label="q_fever_days">
        <inputExpression id="ie_mod_danger_sign_check_4" typeRef="boolean">
          <text>q_fever_days</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_5" label="hx_convulsions">
        <inputExpression id="ie_mod_danger_sign_check_5" typeRef="boolean">
          <text>hx_convulsions</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_6" label="ex_not_able_to_drink_or_feed">
        <inputExpression id="ie_mod_danger_sign_check_6" typeRef="boolean">
          <text>ex_not_able_to_drink_or_feed</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_7" label="ex_vomits_everything">
        <inputExpression id="ie_mod_danger_sign_check_7" typeRef="boolean">
          <text>ex_vomits_everything</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_8" label="ex_chest_indrawing">
        <inputExpression id="ie_mod_danger_sign_check_8" typeRef="boolean">
          <text>ex_chest_indrawing</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_9" label="ex_unusually_sleepy_or_unconscious">
        <inputExpression id="ie_mod_danger_sign_check_9" typeRef="boolean">
          <text>ex_unusually_sleepy_or_unconscious</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_10" label="v_muac_category">
        <inputExpression id="ie_mod_danger_sign_check_10" typeRef="boolean">
          <text>v_muac_category</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_11" label="ex_swelling_both_feet">
        <inputExpression id="ie_mod_danger_sign_check_11" typeRef="boolean">
          <text>ex_swelling_both_feet</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_12" label="ex_fast_breathing">
        <inputExpression id="ie_mod_danger_sign_check_12" typeRef="boolean">
          <text>ex_fast_breathing</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_13" label="lab_rdt_result">
        <inputExpression id="ie_mod_danger_sign_check_13" typeRef="boolean">
          <text>lab_rdt_result</text>
        </inputExpression>
      </input>
      <input id="input_mod_danger_sign_check_14" label="p_malaria_area">
        <inputExpression id="ie_mod_danger_sign_check_14" typeRef="boolean">
          <text>p_malaria_area</text>
        </inputExpression>
      </input>
      <output id="output_mod_danger_sign_check_0" label="p_danger_sign_present" name="p_danger_sign_present" typeRef="string"/>
      <output id="output_mod_danger_sign_check_1" label="p_danger_sign_cough_long" name="p_danger_sign_cough_long" typeRef="string"/>
      <output id="output_mod_danger_sign_check_2" label="p_danger_sign_diarrhoea_long" name="p_danger_sign_diarrhoea_long" typeRef="string"/>
      <output id="output_mod_danger_sign_check_3" label="p_danger_sign_blood_in_stool" name="p_danger_sign_blood_in_stool" typeRef="string"/>
      <output id="output_mod_danger_sign_check_4" label="p_danger_sign_fever_long" name="p_danger_sign_fever_long" typeRef="string"/>
      <output id="output_mod_danger_sign_check_5" label="p_danger_sign_convulsions" name="p_danger_sign_convulsions" typeRef="string"/>
      <output id="output_mod_danger_sign_check_6" label="p_danger_sign_not_able_to_drink_or_feed" name="p_danger_sign_not_able_to_drink_or_feed" typeRef="string"/>
      <output id="output_mod_danger_sign_check_7" label="p_danger_sign_vomits_everything" name="p_danger_sign_vomits_everything" typeRef="string"/>
      <output id="output_mod_danger_sign_check_8" label="p_danger_sign_chest_indrawing" name="p_danger_sign_chest_indrawing" typeRef="string"/>
      <output id="output_mod_danger_sign_check_9" label="p_danger_sign_sleepy_unconscious" name="p_danger_sign_sleepy_unconscious" typeRef="string"/>
      <output id="output_mod_danger_sign_check_10" label="p_danger_sign_red_muac" name="p_danger_sign_red_muac" typeRef="string"/>
      <output id="output_mod_danger_sign_check_11" label="p_danger_sign_swelling_both_feet" name="p_danger_sign_swelling_both_feet" typeRef="string"/>
      <output id="output_mod_danger_sign_check_12" label="p_severely_ill_cannot_drink" name="p_severely_ill_cannot_drink" typeRef="string"/>
      <output id="output_mod_danger_sign_check_13" label="rx_pre_referral_ors" name="rx_pre_referral_ors" typeRef="string"/>
      <output id="output_mod_danger_sign_check_14" label="rx_pre_referral_rectal_artesunate_suppositories" name="rx_pre_referral_rectal_artesunate_suppositories" typeRef="string"/>
      <output id="output_mod_danger_sign_check_15" label="rx_pre_referral_al_first_dose_tabs" name="rx_pre_referral_al_first_dose_tabs" typeRef="string"/>
      <output id="output_mod_danger_sign_check_16" label="rx_pre_referral_amoxicillin_first_dose_tabs" name="rx_pre_referral_amoxicillin_first_dose_tabs" typeRef="string"/>
      <output id="output_mod_danger_sign_check_17" label="ref_urgent_referral" name="ref_urgent_referral" typeRef="string"/>
      <output id="output_mod_danger_sign_check_18" label="ref_referral_destination" name="ref_referral_destination" typeRef="string"/>
      <output id="output_mod_danger_sign_check_19" label="ref_referral_reason" name="ref_referral_reason" typeRef="string"/>
      <output id="output_mod_danger_sign_check_20" label="adv_home_care_more_fluids" name="adv_home_care_more_fluids" typeRef="string"/>
      <output id="output_mod_danger_sign_check_21" label="adv_home_care_continue_feeding" name="adv_home_care_continue_feeding" typeRef="string"/>
      <output id="output_mod_danger_sign_check_22" label="adv_home_care_when_to_return" name="adv_home_care_when_to_return" typeRef="string"/>
      <output id="output_mod_danger_sign_check_23" label="adv_home_care_bednet" name="adv_home_care_bednet" typeRef="string"/>
      <output id="output_mod_danger_sign_check_24" label="fu_follow_up_days" name="fu_follow_up_days" typeRef="string"/>
      <output id="output_mod_danger_sign_check_25" label="mod_danger_sign_check_done" name="mod_danger_sign_check_done" typeRef="string"/>
      <rule id="rule_1">
        <description>Child has a severe danger sign: convulsions, unusually sleepy or unconscious, not able to drink or feed, or vomits everything. Child cannot drink. Give pre-referral ORS and rectal artesunate if fever present (1 suppository for 2mo-3yr, 2 suppositories for 3yr-5yr). Refer urgently to hospital.</description>
        <inputEntry id="ie_mod_danger_sign_check_0_0">
          <text>hx_convulsions == true OR ex_unusually_sleepy_or_unconscious == true OR ex_not_able_to_drink_or_feed == true OR ex_vomits_everything == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_2">
        <description>Child has chest indrawing but can drink (no severe danger signs). Give first dose amoxicillin 250mg (1 tab for 2mo-12mo, 2 tabs for 12mo-5yr). If fever and in malaria area, also give first dose AL (1 tab for 2mo-3yr, 2 tabs for 3yr-5yr). Refer urgently to health facility.</description>
        <inputEntry id="ie_mod_danger_sign_check_1_0">
          <text>hx_convulsions == false AND ex_unusually_sleepy_or_unconscious == false AND ex_not_able_to_drink_or_feed == false AND ex_vomits_everything == false AND ex_chest_indrawing == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_3">
        <description>Child has one or more non-severe danger signs (cough &gt;=14 days, diarrhoea &gt;=14 days, blood in stool, fever &gt;=7 days, red MUAC, or bilateral foot swelling) but can drink and has no chest indrawing. Give ORS if diarrhoea is present. If fever &gt;=7 days and in malaria area give first dose AL. Refer urgently to health facility.</description>
        <inputEntry id="ie_mod_danger_sign_check_2_0">
          <text>hx_convulsions == false AND ex_unusually_sleepy_or_unconscious == false AND ex_not_able_to_drink_or_feed == false AND ex_vomits_everything == false AND ex_chest_indrawing == false AND (q_cough_days &gt;= 14 OR q_diarrhoea_days &gt;= 14 OR q_blood_in_stool == true OR q_fever_days &gt;= 7 OR v_muac_category == 'red' OR ex_swelling_both_feet == true)</text>
        </inputEntry>
      </rule>
      <rule id="rule_4">
        <description>No danger signs detected. Child does not require urgent referral from this module. Proceed to condition-specific assessment modules (diarrhoea, fever, cough/fast breathing, malnutrition). Provide standard home care advice: more fluids, continue feeding, when to return (cannot drink or feed, becomes sicker, develops blood in stool), use bednet. Follow up in 3 days.</description>
        <inputEntry id="ie_mod_danger_sign_check_3_0">
          <text>hx_convulsions == false AND ex_unusually_sleepy_or_unconscious == false AND ex_not_able_to_drink_or_feed == false AND ex_vomits_everything == false AND ex_chest_indrawing == false AND q_cough_days &lt; 14 AND (q_diarrhoea_days == null OR q_diarrhoea_days &lt; 14) AND q_blood_in_stool == false AND (q_fever_days == null OR q_fever_days &lt; 7) AND v_muac_category != 'red' AND ex_swelling_both_feet == false</text>
        </inputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_mod_diarrhoea_treatment" name="Diarrhoea Treatment - ORS and Zinc">
    <variable id="var_decision_mod_diarrhoea_treatment" name="mod_diarrhoea_treatment_output" typeRef="string"/>
