      <output id="output_mod_fast_breathing_treatment_5" label="ref_urgency" name="ref_urgency" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_6" label="ref_reason" name="ref_reason" typeRef="string"/>
      <output id="output_mod_fast_breathing_treatment_7" label="adv_home_care" name="adv_home_care" typeRef="string"/>
