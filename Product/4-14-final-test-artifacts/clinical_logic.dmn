    <decisionTable id="dt_mod_diarrhoea_treatment" hitPolicy="UNIQUE">
      <input id="input_mod_diarrhoea_treatment_0" label="q_has_diarrhoea">
        <inputExpression id="ie_mod_diarrhoea_treatment_0" typeRef="boolean">
          <text>q_has_diarrhoea</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_1" label="q_diarrhoea_days">
        <inputExpression id="ie_mod_diarrhoea_treatment_1" typeRef="boolean">
          <text>q_diarrhoea_days</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_2" label="q_blood_in_stool">
        <inputExpression id="ie_mod_diarrhoea_treatment_2" typeRef="boolean">
          <text>q_blood_in_stool</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_3" label="ex_not_able_to_drink_or_feed">
        <inputExpression id="ie_mod_diarrhoea_treatment_3" typeRef="boolean">
          <text>ex_not_able_to_drink_or_feed</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_4" label="ex_vomits_everything">
        <inputExpression id="ie_mod_diarrhoea_treatment_4" typeRef="boolean">
          <text>ex_vomits_everything</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_5" label="ex_chest_indrawing">
        <inputExpression id="ie_mod_diarrhoea_treatment_5" typeRef="boolean">
          <text>ex_chest_indrawing</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_6" label="ex_unusually_sleepy_or_unconscious">
        <inputExpression id="ie_mod_diarrhoea_treatment_6" typeRef="boolean">
          <text>ex_unusually_sleepy_or_unconscious</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_7" label="ex_convulsions">
        <inputExpression id="ie_mod_diarrhoea_treatment_7" typeRef="boolean">
          <text>ex_convulsions</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_8" label="v_muac_category">
        <inputExpression id="ie_mod_diarrhoea_treatment_8" typeRef="boolean">
          <text>v_muac_category</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_9" label="ex_swelling_both_feet">
        <inputExpression id="ie_mod_diarrhoea_treatment_9" typeRef="boolean">
          <text>ex_swelling_both_feet</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_10" label="q_cough_days">
        <inputExpression id="ie_mod_diarrhoea_treatment_10" typeRef="boolean">
          <text>q_cough_days</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_11" label="q_fever_days">
        <inputExpression id="ie_mod_diarrhoea_treatment_11" typeRef="boolean">
          <text>q_fever_days</text>
        </inputExpression>
      </input>
      <input id="input_mod_diarrhoea_treatment_12" label="demo_age_months">
        <inputExpression id="ie_mod_diarrhoea_treatment_12" typeRef="boolean">
          <text>demo_age_months</text>
        </inputExpression>
      </input>
      <output id="output_mod_diarrhoea_treatment_0" label="rx_ors" name="rx_ors" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_1" label="rx_zinc_dose_label" name="rx_zinc_dose_label" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_2" label="rx_zinc_tablets_per_dose" name="rx_zinc_tablets_per_dose" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_3" label="rx_zinc_doses_per_day" name="rx_zinc_doses_per_day" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_4" label="rx_zinc_duration_days" name="rx_zinc_duration_days" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_5" label="rx_zinc_total_tablets" name="rx_zinc_total_tablets" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_6" label="rx_pre_referral_ors" name="rx_pre_referral_ors" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_7" label="ref_urgently" name="ref_urgently" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_8" label="ref_destination" name="ref_destination" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_9" label="ref_reason" name="ref_reason" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_10" label="adv_more_fluids" name="adv_more_fluids" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_11" label="adv_continue_feeding" name="adv_continue_feeding" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_12" label="adv_when_to_return" name="adv_when_to_return" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_13" label="adv_bednet" name="adv_bednet" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_14" label="fu_follow_up_days" name="fu_follow_up_days" typeRef="string"/>
      <output id="output_mod_diarrhoea_treatment_15" label="mod_diarrhoea_treatment_done" name="mod_diarrhoea_treatment_done" typeRef="string"/>
      <rule id="rule_1">
        <description>Diarrhoea lasting 14 or more days is a danger sign. Give ORS as pre-referral treatment and refer urgently to health facility.</description>
        <inputEntry id="ie_mod_diarrhoea_treatment_0_0">
          <text>q_has_diarrhoea == true &amp;&amp; q_diarrhoea_days &gt;= 14</text>
        </inputEntry>
      </rule>
      <rule id="rule_2">
        <description>Blood in stool is a danger sign. Give ORS as pre-referral treatment and refer urgently to health facility.</description>
        <inputEntry id="ie_mod_diarrhoea_treatment_1_0">
          <text>q_has_diarrhoea == true &amp;&amp; q_blood_in_stool == true</text>
        </inputEntry>
      </rule>
      <rule id="rule_3">
        <description>General danger sign present alongside diarrhoea (not able to drink/feed, vomits everything, unusually sleepy or unconscious, convulsions). Give ORS as pre-referral and refer urgently.</description>
        <inputEntry id="ie_mod_diarrhoea_treatment_2_0">
          <text>q_has_diarrhoea == true &amp;&amp; (ex_not_able_to_drink_or_feed == true || ex_vomits_everything == true || ex_unusually_sleepy_or_unconscious == true || ex_convulsions == true)</text>
        </inputEntry>
      </rule>
      <rule id="rule_4">
        <description>Other danger sign present alongside diarrhoea (chest indrawing, red MUAC, bilateral foot oedema, cough &gt;= 14 days, fever &gt;= 7 days). Give ORS as pre-referral and refer urgently.</description>
        <inputEntry id="ie_mod_diarrhoea_treatment_3_0">
          <text>q_has_diarrhoea == true &amp;&amp; (ex_chest_indrawing == true || v_muac_category == 'red' || ex_swelling_both_feet == true || q_cough_days &gt;= 14 || q_fever_days &gt;= 7)</text>
        </inputEntry>
      </rule>
      <rule id="rule_5">
        <description>Uncomplicated diarrhoea (&lt; 14 days, no blood in stool, no danger signs) in child aged 2 to &lt; 6 months. Give ORS and zinc half tablet (10mg) once daily for 10 days (5 tablets total). Provide home care advice and follow up in 3 days.</description>
        <inputEntry id="ie_mod_diarrhoea_treatment_4_0">
          <text>q_has_diarrhoea == true &amp;&amp; q_diarrhoea_days &lt; 14 &amp;&amp; q_blood_in_stool == false &amp;&amp; ex_not_able_to_drink_or_feed == false &amp;&amp; ex_vomits_everything == false &amp;&amp; ex_unusually_sleepy_or_unconscious == false &amp;&amp; ex_convulsions == false &amp;&amp; ex_chest_indrawing == false &amp;&amp; v_muac_category != 'red' &amp;&amp; ex_swelling_both_feet == false &amp;&amp; q_cough_days &lt; 14 &amp;&amp; q_fever_days &lt; 7 &amp;&amp; demo_age_months &gt;= 2 &amp;&amp; demo_age_months &lt; 6</text>
        </inputEntry>
      </rule>
      <rule id="rule_6">
        <description>Uncomplicated diarrhoea (&lt; 14 days, no blood in stool, no danger signs) in child aged 6 months to &lt; 5 years. Give ORS and zinc 1 tablet (20mg) once daily for 10 days (10 tablets total). Provide home care advice and follow up in 3 days.</description>
        <inputEntry id="ie_mod_diarrhoea_treatment_5_0">
          <text>q_has_diarrhoea == true &amp;&amp; q_diarrhoea_days &lt; 14 &amp;&amp; q_blood_in_stool == false &amp;&amp; ex_not_able_to_drink_or_feed == false &amp;&amp; ex_vomits_everything == false &amp;&amp; ex_unusually_sleepy_or_unconscious == false &amp;&amp; ex_convulsions == false &amp;&amp; ex_chest_indrawing == false &amp;&amp; v_muac_category != 'red' &amp;&amp; ex_swelling_both_feet == false &amp;&amp; q_cough_days &lt; 14 &amp;&amp; q_fever_days &lt; 7 &amp;&amp; demo_age_months &gt;= 6 &amp;&amp; demo_age_months &lt; 60</text>
        </inputEntry>
      </rule>
    </decisionTable>
  </decision>
  <decision id="decision_mod_fast_breathing_treatment" name="Fast Breathing Treatment - Amoxicillin">
    <variable id="var_decision_mod_fast_breathing_treatment" name="mod_fast_breathing_treatment_output" typeRef="string"/>
    <informationRequirement id="ir_mod_fast_breathing_treatment_p_fast_breathing">
