          <text>ex_convulsions</text>
        </inputExpression>
      </input>
      <input id="input_mod_fast_breathing_treatment_7" label="ex_unusually_sleepy_or_unconscious">
        <inputExpression id="ie_mod_fast_breathing_treatment_7" typeRef="boolean">
